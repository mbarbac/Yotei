<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
	  <TargetFramework>net8.0</TargetFramework>
	  <LangVersion>latest</LangVersion>
	  <ImplicitUsings>disable</ImplicitUsings>
	  <Nullable>enable</Nullable>
	  <Configurations>Debug;Release;Local</Configurations>
   </PropertyGroup>

   <!-- DEBUG configuration -->
   <ItemGroup Condition="'$(Configuration)'=='Debug'">
	  <ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
	  <ProjectReference Include="..\..\1-Yotei.Tools.LambdaParser\Yotei.Tools.LambdaParser\Yotei.Tools.LambdaParser.csproj" />
	  <ProjectReference Include="..\..\1-Yotei.Tools.Generators\Yotei.Tools.CloneGenerator\Yotei.Tools.CloneGenerator.csproj">
		 <OutputItemType>Analyzer</OutputItemType>
		 <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
	  </ProjectReference>
	  <ProjectReference Include="..\..\1-Yotei.Tools.Generators\Yotei.Tools.WithGenerator\Yotei.Tools.WithGenerator.csproj">
		 <OutputItemType>Analyzer</OutputItemType>
		 <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
	  </ProjectReference>
   </ItemGroup>

   <!--LOCAL configuration-->
   <ItemGroup Condition="'$(Configuration)'=='Local'">
	  <PackageReference Include="Yotei.Tools" Version="0.5.31-v0001" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.5.27-v0001" />
	  <PackageReference Include="Yotei.Tools.WithGenerator" Version="0.5.21-v0001" />
	  <PackageReference Include="Yotei.Tools.CloneGenerator" Version="0.5.21-v0001" />
	  <ProjectReference Include="..\Kappa.Tools\Kappa.Tools.csproj" />
   </ItemGroup>

   <!-- RELEASE configuration -->
   <ItemGroup Condition="'$(Configuration)'=='Release'">
	  <PackageReference Include="Yotei.Tools" Version="0.5.30" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.5.26" />
	  <PackageReference Include="Yotei.Tools.WithGenerator" Version="0.5.20" />
	  <PackageReference Include="Yotei.Tools.CloneGenerator" Version="0.5.20" />
	  <ProjectReference Include="..\Kappa.Tools\Kappa.Tools.csproj" />
   </ItemGroup>

   <!-- Emit generated files -->
   <ItemGroup>
	  <Compile Remove="$(CompilerGeneratedFilesOutputPath)/**/*.cs" />
   </ItemGroup>

   <PropertyGroup>
	  <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
	  <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	  <CompilerGeneratedFilesOutputPath>Generated\$(TargetFramework)</CompilerGeneratedFilesOutputPath>
   </PropertyGroup>

   <!-- Clear generated files each compile or build -->
   <!-- Need to appear at the end of the file -->
   <Target Name="CustomBeforeCompile" BeforeTargets="BeforeCompile">
	  <RemoveDir Directories="$(ProjectDir)\Generated\" />
   </Target>
   <Target Name="CustomBeforeBuild" BeforeTargets="BeforeBuild">
	  <RemoveDir Directories="$(ProjectDir)\Generated\" />
   </Target>

</Project>
