<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
	  <TargetFramework>net8.0</TargetFramework>
	  <ImplicitUsings>disable</ImplicitUsings>
	  <Nullable>enable</Nullable>
	  <LangVersion>latest</LangVersion>
	  <Configurations>Debug;Release;Local</Configurations>
   </PropertyGroup>

   <PropertyGroup>
	  <Description>Yotei ORM Entities Framework</Description>
	  <Version>0.2.2-v0001</Version>
	  <Authors>mbarbac@hotmail.com</Authors>
	  <PackageProjectUrl>https://github.com/mbarbac/Yotei</PackageProjectUrl>
	  <IsPackable>true</IsPackable>
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  <IncludeSymbols>true</IncludeSymbols>
	  <SymbolPackageFormat>snupkg</SymbolPackageFormat>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
	  <PackageLicenseFile>LICENSE</PackageLicenseFile>
   </PropertyGroup>
   
   <ItemGroup>
	  <None Include="README.md" Pack="true" PackagePath="" />
	  <None Include="LICENSE" Pack="true" PackagePath="" />
   </ItemGroup>

   <ItemGroup Condition="'$(Configuration)'=='Debug'">
	  <ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
	  <ProjectReference Include="..\..\1-Yotei.Tools.LambdaParser\Yotei.Tools.LambdaParser\Yotei.Tools.LambdaParser.csproj" />
	  <ProjectReference Include="..\..\2-Yotei.ORM.Core\Yotei.ORM.Core\Yotei.ORM.Core.csproj" />
   </ItemGroup>

   <ItemGroup Condition="'$(Configuration)'=='Local'">
	  <PackageReference Include="Yotei.Tools" Version="0.5.23-v0001" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.5.20-v0001" />
	  <PackageReference Include="Yotei.ORM.Core" Version="0.2.4-v0001" />
   </ItemGroup>

   <ItemGroup Condition="'$(Configuration)'=='Release'">
	  <PackageReference Include="Yotei.Tools" Version="0.5.22" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.5.19" />
	  <PackageReference Include="Yotei.ORM.Core" Version="0.2.3" />
   </ItemGroup>
</Project>
