<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
	  <TargetFramework>net10.0</TargetFramework>
	  <LangVersion>preview</LangVersion>
	  <ImplicitUsings>disable</ImplicitUsings>
	  <Nullable>enable</Nullable>
	  <Configurations>Debug;Release;Local</Configurations>
	  <NoWarn>IDE0130;IDE0290</NoWarn>
   </PropertyGroup>
   <!--IDE0130: Folder structure-->
   <!--IDE0290: Primary constructor-->

   <PropertyGroup>
	  <Description>Yotei ORM</Description>
	  <Version>0.7.0-v0001</Version>
	  <Authors>mbarbac@hotmail.com</Authors>
	  <PackageProjectUrl>https://gitbug.com/mbarbac/Yotei</PackageProjectUrl>
	  <IsPackable>true</IsPackable>
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  <IncludeSymbols>true</IncludeSymbols>
	  <SymbolPackageFormat>snupkg</SymbolPackageFormat>
	  <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
   </PropertyGroup>

   <ItemGroup>
     <Compile Remove="1.Core\Connection.cs" />
     <Compile Remove="1.Core\Engine.cs" />
     <Compile Remove="1.Core\Identifier.cs" />
     <Compile Remove="1.Core\IdentifierChain.cs" />
     <Compile Remove="1.Core\IdentifierChain_Builder.cs" />
     <Compile Remove="1.Core\IdentifierUnit.cs" />
     <Compile Remove="1.Core\Transaction.cs" />
     <Compile Remove="5.Tools.Collections\CoreList[K,T].cs" />
     <Compile Remove="5.Tools.Collections\CoreList[T].cs" />
     <Compile Remove="5.Tools.Collections\InvariantList[K,T].cs" />
     <Compile Remove="5.Tools.Collections\InvariantList[T].cs" />
   </ItemGroup>

   <ItemGroup>
	  <None Include="README.md" Pack="true" PackagePath="" />
	  <None Include="LICENSE.txt" Pack="true" PackagePath="" />
   </ItemGroup>

   <!-- DEBUG configuration -->
   <ItemGroup Condition="'$(Configuration)'=='Debug'">
	  <ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
	  <ProjectReference Include="..\..\1-Yotei.Tools.LamdaParser\Yotei.Tools.LambdaParser\Yotei.Tools.LambdaParser.csproj" />
	  <ProjectReference Include="..\..\1-Yotei.Tools.AsyncLock\Yotei.Tools.AsyncLock\Yotei.Tools.AsyncLock.csproj" />
   </ItemGroup>

   <!-- RELEASE configuration -->
   <ItemGroup Condition="'$(Configuration)'=='Release'">
	  <PackageReference Include="Yotei.Tools" Version="0.7.1" />
	  <PackageReference Include="Yotei.Tools.AsyncLock" Version="0.7.0" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.7.0" />
	  <PackageReference Include="Yotei.Tools.AsyncLock" Version="0.7.0" />
   </ItemGroup>

   <!-- LOCAL configuration -->
   <ItemGroup Condition="'$(Configuration)'=='Local'">
	  <PackageReference Include="Yotei.Tools" Version="0.7.1-v0001" />
	  <PackageReference Include="Yotei.Tools.AsyncLock" Version="0.7.0-v0001" />
	  <PackageReference Include="Yotei.Tools.LambdaParser" Version="0.7.0-v0001" />
	  <PackageReference Include="Yotei.Tools.AsyncLock" Version="0.7.0-v0001" />
   </ItemGroup>
   <ItemGroup>
     <Folder Include="1.Core\" />
   </ItemGroup>

</Project>
