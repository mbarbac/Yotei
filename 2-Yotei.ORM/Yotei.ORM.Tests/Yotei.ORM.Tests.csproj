<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Configurations>Debug;Release;Local</Configurations>
		<TargetFramework>net10.0</TargetFramework>
		<LangVersion>preview</LangVersion>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<NoWarn>IDE0130</NoWarn>
	</PropertyGroup>
	<!--IDE0130: Namespace does not match folder structure-->

	<ItemGroup>
		<PackageReference Include="coverlet.collector" Version="8.0.1">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
		<PackageReference Include="xunit.v3" Version="3.2.2" />
		<PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<!-- DEBUG configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Debug'">
		<ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
		<ProjectReference Include="..\..\1-Yotei.Tools.Generators\01-CloneGenerator\Yotei.Tools.CloneGenerator\Yotei.Tools.CloneGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\..\1-Yotei.Tools.Generators\02-WithGenerator\Yotei.Tools.WithGenerator\Yotei.Tools.WithGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\Yotei.ORM\Yotei.ORM.csproj" />
	</ItemGroup>

	<!-- RELEASE configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Release'">
		<PackageReference Include="Yotei.Tools" Version="0.6.5" />
		<PackageReference Include="Yotei.Tools.CloneGenerator" Version="0.6.5" />
		<PackageReference Include="Yotei.Tools.WithGenerator" Version="0.6.5" />
		<PackageReference Include="Yotei.ORM" Version="0.6.5" />
	</ItemGroup>

	<!-- LOCAL configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Local'">
		<PackageReference Include="Yotei.Tools" Version="0.6.5-v0001" />
		<PackageReference Include="Yotei.Tools.CloneGenerator" Version="0.6.5-v0001" />
		<PackageReference Include="Yotei.Tools.WithGenerator" Version="0.6.5-v0001" />
		<PackageReference Include="Yotei.ORM" Version="0.6.5-v0001" />
	</ItemGroup>

	<!--Generator configuration options-->
	<ItemGroup>
		<AdditionalFiles Include="TreeGeneratorOptions.ini" />
	</ItemGroup>

	<!-- Emit generated files -->
	<PropertyGroup>
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
		<CompilerGeneratedFilesOutputPath>Generated\$(TargetFramework)</CompilerGeneratedFilesOutputPath>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="$(CompilerGeneratedFilesOutputPath)/**/**" />
		<Compile Remove="$(CompilerGeneratedFilesOutputPath)/**" />
	</ItemGroup>

	<!-- Clear generated files each compile or build (need to be at the end of the file)-->
	<Target Name="CustomBeforeCompile" BeforeTargets="BeforeCompile">
		<RemoveDir Directories="$(ProjectDir)\Generated\" />
	</Target>
	<Target Name="CustomBeforeBuild" BeforeTargets="BeforeBuild">
		<RemoveDir Directories="$(ProjectDir)\Generated\" />
	</Target>

</Project>