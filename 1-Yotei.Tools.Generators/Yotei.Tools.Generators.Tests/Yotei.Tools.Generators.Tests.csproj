<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
	  <TargetFramework>net8.0</TargetFramework>
	  <ImplicitUsings>disable</ImplicitUsings>
	  <Nullable>enable</Nullable>
	  <LangVersion>latest</LangVersion>
	  <IsPackable>false</IsPackable>
	  <IsTestProject>true</IsTestProject>
	  <Configurations>Debug;Release;Local</Configurations>
	  <NoWarn>CS0436</NoWarn>
   </PropertyGroup>

   <ItemGroup>
	  <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.7.2" />
	  <PackageReference Include="xunit" Version="2.5.2" />
	  <PackageReference Include="xunit.runner.visualstudio" Version="2.5.3">
		 <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		 <PrivateAssets>all</PrivateAssets>
	  </PackageReference>
	  <PackageReference Include="coverlet.collector" Version="6.0.0">
		 <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		 <PrivateAssets>all</PrivateAssets>
	  </PackageReference>
   </ItemGroup>

   <Import Project="..\Yotei.Tools.Generators\Yotei.Tools.Generators.projitems" Label="Shared" />

   <ItemGroup Condition="'$(Configuration)'=='Debug'">
	  <ProjectReference Include="..\Yotei.Tools.Generators.Wrap\Yotei.Tools.Generators.Wrap.csproj" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.7.0" PrivateAssets="all" />
	  <ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
   </ItemGroup>

   <ItemGroup Condition="'$(Configuration)'=='Local'">
	  <ProjectReference Include="..\Yotei.Tools.Generators.Wrap\Yotei.Tools.Generators.Wrap.csproj" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.7.0" PrivateAssets="all" />
	  <PackageReference Include="Yotei.Tools" Version="0.5.23-v0001" />
   </ItemGroup>

   <ItemGroup Condition="'$(Configuration)'=='Release'">
	  <ProjectReference Include="..\Yotei.Tools.Generators.Wrap\Yotei.Tools.Generators.Wrap.csproj" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.7.0" PrivateAssets="all" />
	  <PackageReference Include="Yotei.Tools" Version="0.5.22" />
   </ItemGroup>

   <ItemGroup>
	  <Compile Remove="$(CompilerGeneratedFilesOutputPath)/**/*.cs" />
   </ItemGroup>
   <PropertyGroup>
	  <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	  <CompilerGeneratedFilesOutputPath>Generated\$(TargetFramework)</CompilerGeneratedFilesOutputPath>
   </PropertyGroup>

   <!--Need to appear at the end of the file-->
   <Target Name="CustomBeforeCompile" BeforeTargets="BeforeCompile">
	  <RemoveDir Directories="$(ProjectDir)\Generated\" />
   </Target>
   <Target Name="CustomBeforeBuild" BeforeTargets="BeforeBuild">
	  <RemoveDir Directories="$(ProjectDir)\Generated\" />
   </Target>
</Project>
