<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Configurations>Debug;Release;Local</Configurations>
		<TargetFramework>net10.0</TargetFramework>
		<LangVersion>preview</LangVersion>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<NoWarn>IDE0130;CS0436</NoWarn>
	</PropertyGroup>

	<!-- DEBUG configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Debug'">
		<ProjectReference Include="..\..\1-Yotei.Tools\Yotei.Tools\Yotei.Tools.csproj" />
	</ItemGroup>

	<!-- RELEASE configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Release'">
		<PackageReference Include="Yotei.Tools" Version="0.6.5" />
	</ItemGroup>

	<!-- LOCAL configuration -->
	<ItemGroup Condition="'$(Configuration)'=='Local'">
		<PackageReference Include="Yotei.Tools" Version="0.6.5-v0001" />
	</ItemGroup>

</Project>
